def en_iyi_senaryo_bul():
    print("\n EN İYİ SENARYO ANALİZİ")

    ref = senaryolar["Mevcut Durum"]

    sonuc_tablosu = []

    for ad, s in senaryolar.items():

        # yatırım
        yatirim = arac_yatirim_maliyeti(s)

        # yıllık maliyet (ortalama 10 yıl)
        toplam_maliyet = 0
        toplam_emisyon = 0

        for yil in range(1, ANALIZ_YILI + 1):
            tufe_kat = (1 + tufe_oran) ** (yil - 1)

            yakit = yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
            bakim = yillik_bakim_maliyeti(s, tufe_kat)

            toplam_maliyet += (yakit + bakim)
            toplam_emisyon += emisyonlar[ad]["WTW_CO2"]

        ort_maliyet = toplam_maliyet / ANALIZ_YILI

        # --- SKOR (Ağırlıklı karar modeli) ---
        # %60 maliyet + %40 emisyon (istersen değiştirebilirsin)
        maliyet_skor = ort_maliyet
        emisyon_skor = emisyonlar[ad]["WTW_CO2"] * 1e6  # ölçekleme

        skor = (0.6 * maliyet_skor) + (0.4 * emisyon_skor)

        sonuc_tablosu.append({
            "Senaryo": ad,
            "Yatırım": yatirim,
            "Ortalama Yıllık Maliyet": ort_maliyet,
            "WTW Emisyon": emisyonlar[ad]["WTW_CO2"],
            "Skor": skor
        })

    df = pd.DataFrame(sonuc_tablosu)

    en_iyi = df.loc[df["Skor"].idxmin()]

    print("\n SENARYO KARŞILAŞTIRMA TABLOSU")
    print(df.sort_values("Skor").to_string(index=False))

    print("\n EN İYİ SENARYO:")
    print(f"    {en_iyi['Senaryo']}")
    print(f"    Ortalama Maliyet : {fmt_number(en_iyi['Ortalama Yıllık Maliyet'])} ₺")
    print(f"    Emisyon          : {en_iyi['WTW Emisyon']:.1f} ton CO₂e/yıl")

