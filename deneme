def basbas_serileri(df_sen, df_md_ref, yatirim_toplam):
    """
    Kümülatif net nakit akışı hesaplar:
      - Ay 0 öncesi: −yatirim_toplam (ilk yatırım gideri)
      - Her ay: MD aylık maliyeti − Senaryo aylık maliyeti = aylık tasarruf
      - Kümülatif tasarruf yatırımı karşıladığında başa baş noktasına ulaşılır.
    """
    # Aylık tasarruf = mevcut durum gideri − senaryo gideri (yakıt+bakım, taksitsiz)
    # Senaryo için sadece yakıt+bakım giderini kullanıyoruz (taksit ayrı ele alındı)
    tasarruf_aylik = (df_md_ref["yakıt"] + df_md_ref["bakım"]).values - \
                     (df_sen["yakıt"]   + df_sen["bakım"]).values

    # Kümülatif: başlangıç = −yatırım, sonra her ay tasarruf eklenir
    kumul = np.cumsum(tasarruf_aylik) - yatirim_toplam
    return kumul

def yatirim_hesapla(n_oto_ev, n_mini_ev):
    return n_oto_ev * fiyat_otobüs_ev + n_mini_ev * fiyat_minibüs_ev

