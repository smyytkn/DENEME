        fig.add_trace(fgo.Scatter(x=yillar, y=[v['yillik_tasarruf'] for v in s3['veriler']], name="S3 Yıllık Tasarruf", stackgroup="three", line=dict(color=COLORS['s3'])))
        fig.update_layout(title="Mevcut Duruma Kıymatla Sağlanan Net Yıllık Tasarruf", **chart_layout)
        st.plotly_chart(fig, use_container_width=True)

    elif "Gideri" in chart_type:
        fig = fgo.Figure()
