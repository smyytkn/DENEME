def grafik_emisyon(emisyonlar, senaryolar):
    fig, axes = plt.subplots(2, 3, figsize=(16, 9))
    fig.suptitle("Senaryo Bazlı Emisyon Faktörü Karşılaştırması\n(Well-to-Wheel Metodolojisi)",
                 fontsize=14, fontweight="bold", y=1.01)

    metrikler = [
        ("WTW_CO2", "WTW CO₂e (ton/yıl)",  "Tam Yakıt Döngüsü"),
        ("TTW_CO2", "TTW CO₂e (ton/yıl)",  "Tank-to-Wheel"),
        ("WTT_CO2", "WTT CO₂e (ton/yıl)",  "Well-to-Tank"),
        ("NOx",     "NOx (ton/yıl)",        "Azot Oksitler"),
        ("PM",      "PM (ton/yıl)",         "Partikül Madde"),
        ("HC",      "HC (ton/yıl)",         "Hidrokarbonlar"),
    ]
    senaryo_adlari = list(senaryolar.keys())
    x = np.arange(len(senaryo_adlari))

    for ax, (metrik, ylabel, baslik) in zip(axes.flat, metrikler):
        degerler = [emisyonlar[ad][metrik] for ad in senaryo_adlari]
        renkler  = [RENKLER[ad] for ad in senaryo_adlari]
        bars = ax.bar(x, degerler, color=renkler, width=0.55, alpha=0.88, edgecolor="white")
        for bar, val in zip(bars, degerler):
            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + max(degerler)*0.01,
                    f"{val:,.1f}", ha="center", va="bottom", fontsize=8, fontweight="bold")
        ax.set_xticks(x)
        ax.set_xticklabels(senaryo_adlari, fontsize=8, rotation=15, ha="right")
        ax.set_ylabel(ylabel, fontsize=9)
        ax.set_title(baslik, fontsize=10, fontweight="bold")
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, p: f"{v:,.0f}"))
        ref = degerler[0]
        for i, (bar, val) in enumerate(zip(bars, degerler)):
            if i > 0 and ref > 0:
                az = (ref - val) / ref * 100
                ax.text(bar.get_x() + bar.get_width()/2, bar.get_height()/2,
                        f"−{az:.0f}%", ha="center", va="center",
                        color="white", fontsize=7, fontweight="bold")

    patches = [mpatches.Patch(color=RENKLER[ad], label=ad) for ad in senaryo_adlari]
    fig.legend(handles=patches, loc="lower center", ncol=4, frameon=True,
               fontsize=9, bbox_to_anchor=(0.5, -0.04))
    plt.tight_layout()
    return fig


def grafik_mevcut_durum(analiz_yili, senaryolar):
    s = senaryolar["Mevcut Durum"]
    giderler = []
    for yil in range(1, analiz_yili + 1):
        tufe_kat = (1 + tufe_oran) ** (yil - 1)
        aylik = (yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
                 yillik_bakim_maliyeti(s, tufe_kat)) / 12
        giderler.extend([aylik] * 12)

    fig, ax = plt.subplots(figsize=(14, 5))
    for yil in range(1, analiz_yili + 1):
        start, end = (yil - 1) * 12, yil * 12
        c = "#1A5276" if yil % 2 == 1 else "#1E8449"
        ax.plot(list(range(start, end)), giderler[start:end], color=c, linewidth=2)
        ax.fill_between(list(range(start, end)), giderler[start:end], alpha=0.08, color=c)
    ax.set_title(f"Mevcut Durum – Aylık Toplam Gider ({analiz_yili} Yıl | TÜFE dahil)",
                 fontsize=12, fontweight="bold")
    ax.set_xlabel("Ay")
    ax.set_ylabel("Aylık Gider (₺)")
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, p: f"{v:,.0f} ₺"))
    ax.set_xticks(range(0, len(giderler), 12))
    ax.set_xticklabels([f"Yıl {i+1}" for i in range(analiz_yili)])
    ax.legend(handles=[
        mpatches.Patch(color="#1A5276", label="Tek Yıllar"),
        mpatches.Patch(color="#1E8449", label="Çift Yıllar"),
    ], loc="upper left")
    plt.tight_layout()
    return fig


def grafik_senaryo_maliyet(senaryo_adi, s, ref_s, emisyonlar, analiz_yili, amorti_yil):
    renk    = RENKLER[senaryo_adi]
    yatirim = arac_yatirim_maliyeti(s)
    annuity_b = sum((1 + tufe_oran)**k for k in range(analiz_yili))
    baz_odeme = yatirim / annuity_b if annuity_b > 0 else 0

    kum_net = 0
    yillik_netleri, yil_odeme, yil_toplam = [], [], []
    kum_e_ref = kum_e_yeni = 0
    odeme_plani = []

    for yil in range(1, analiz_yili + 1):
        tufe_kat   = (1 + tufe_oran) ** (yil - 1)
        y_yeni     = yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
        b_yeni     = yillik_bakim_maliyeti(s, tufe_kat)
        y_ref      = yillik_yakit_maliyeti(ref_s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
        b_ref      = yillik_bakim_maliyeti(ref_s, tufe_kat)
        tasarruf   = (y_ref + b_ref) - (y_yeni + b_yeni)
        odeme      = baz_odeme * tufe_kat
        kum_net   += tasarruf - odeme
        yillik_netleri.append(kum_net)
        yil_odeme.append(odeme)
        yil_toplam.append(y_yeni + b_yeni + odeme)
        kum_e_ref  += emisyonlar["Mevcut Durum"]["WTW_CO2"]
        kum_e_yeni += emisyonlar[senaryo_adi]["WTW_CO2"]
        odeme_plani.append({
            "Yıl": yil,
            "Aylık Taksit (₺)": f"{odeme/12:,.0f}",
            "Yıllık Taksit (₺)": f"{odeme:,.0f}",
            "Yıllık Tasarruf (₺)": f"{tasarruf:,.0f}",
            "Kümülatif Net (₺)": f"{kum_net:,.0f}",
        })

    emisyon_azalma     = kum_e_ref - kum_e_yeni
    emisyon_azalma_pct = emisyon_azalma / kum_e_ref * 100 if kum_e_ref > 0 else 0
    yillar = list(range(1, analiz_yili + 1))

    # ── Grafik 1: Başabaş + Toplam Gider ──
    fig1, axes = plt.subplots(1, 2, figsize=(14, 5))
    fig1.suptitle(
        f"{senaryo_adi} – Başabaş & Maliyet\n"
        f"(Başabaş: {'Yıl ' + str(amorti_yil) if amorti_yil else 'Bulunamadı'} | Dönem: {analiz_yili} yıl)",
        fontsize=13, fontweight="bold"
    )
    ax1 = axes[0]
    ax1.axhline(0, color="black", linewidth=1.2, linestyle="--", alpha=0.6)
    ax1.plot(yillar, yillik_netleri, color=renk, linewidth=2.5, marker="o", markersize=5)
    ax1.fill_between(yillar, yillik_netleri, 0,
                     where=[v >= 0 for v in yillik_netleri], alpha=0.2, color="green", label="Kâr")
    ax1.fill_between(yillar, yillik_netleri, 0,
                     where=[v < 0 for v in yillik_netleri], alpha=0.2, color="red", label="Zarar")
    if amorti_yil:
        ax1.axvline(amorti_yil, color="darkgreen", linestyle=":", linewidth=1.8)
        ax1.text(amorti_yil + 0.1, min(yillik_netleri) * 0.8,
                 f"Başabaş\nYıl {amorti_yil}", color="darkgreen", fontsize=9, fontweight="bold")
    ax1.set_title("Kümülatif Net Tasarruf", fontsize=10, fontweight="bold")
    ax1.set_xlabel("Yıl")
    ax1.set_ylabel("₺")
    ax1.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    ax1.legend()

    ax2 = axes[1]
    ax2.bar(yillar, yil_toplam, color=renk, alpha=0.75, edgecolor="white")
    ax2.set_title("Yıllık Toplam Gider\n(Yakıt + Bakım + Taksit)", fontsize=10, fontweight="bold")
    ax2.set_xlabel("Yıl")
    ax2.set_ylabel("₺")
    ax2.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    plt.tight_layout()

    # ── Grafik 2: Emisyon Azalması ──
    fig2, axes2 = plt.subplots(1, 2, figsize=(14, 5))
    fig2.suptitle(f"{senaryo_adi} – {analiz_yili} Yıllık Emisyon Azalması (Mevcut Duruma Kıyasla)",
                  fontsize=12, fontweight="bold")

    ax_e1 = axes2[0]
    ref_e_yil  = [emisyonlar["Mevcut Durum"]["WTW_CO2"]] * analiz_yili
    yeni_e_yil = [emisyonlar[senaryo_adi]["WTW_CO2"]] * analiz_yili
    ax_e1.plot(yillar, ref_e_yil,  color=RENKLER["Mevcut Durum"], linewidth=2,
               linestyle="--", label="Mevcut Durum")
    ax_e1.plot(yillar, yeni_e_yil, color=renk, linewidth=2.5, marker="o",
               markersize=5, label=senaryo_adi)
    ax_e1.fill_between(yillar, ref_e_yil, yeni_e_yil, alpha=0.18, color=renk,
                       label=f"Azalma: {ref_e_yil[0]-yeni_e_yil[0]:,.1f} ton/yıl")
    ax_e1.set_title("Yıllık WTW CO₂e", fontsize=10, fontweight="bold")
    ax_e1.set_xlabel("Yıl"); ax_e1.set_ylabel("ton CO₂e/yıl")
    ax_e1.legend(fontsize=8)
    ax_e1.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, p: f"{v:,.0f}"))

    ax_e2 = axes2[1]
    kum_ref_s  = [emisyonlar["Mevcut Durum"]["WTW_CO2"] * y for y in yillar]
    kum_yeni_s = [emisyonlar[senaryo_adi]["WTW_CO2"] * y for y in yillar]
    ax_e2.plot(yillar, kum_ref_s,  color=RENKLER["Mevcut Durum"], linewidth=2,
               linestyle="--", label="Mevcut Durum")
    ax_e2.plot(yillar, kum_yeni_s, color=renk, linewidth=2.5, marker="o",
               markersize=5, label=senaryo_adi)
    ax_e2.fill_between(yillar, kum_ref_s, kum_yeni_s, alpha=0.18, color=renk,
                       label=f"Toplam: {emisyon_azalma:,.1f} ton (−%{emisyon_azalma_pct:.1f})")
    ax_e2.set_title(f"Kümülatif CO₂e ({analiz_yili} yıl)", fontsize=10, fontweight="bold")
    ax_e2.set_xlabel("Yıl"); ax_e2.set_ylabel("Kümülatif ton CO₂e")
    ax_e2.legend(fontsize=8)
    ax_e2.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, p: f"{v:,.0f}"))
    plt.tight_layout()

    # ── Grafik 3: Taksit ──
    fig3, ax3 = plt.subplots(figsize=(12, 4))
    ax3.bar(yillar, yil_odeme, color=renk, alpha=0.8, edgecolor="white")
    for y, od in zip(yillar, yil_odeme):
        ax3.text(y, od + max(yil_odeme) * 0.01, f"{od/12:,.0f} ₺/ay",
                 ha="center", va="bottom", fontsize=8)
    ax3.set_title(f"{senaryo_adi} – Yıllık Taksit Ödemesi (TÜFE Artışlı | {analiz_yili} yıl)",
                  fontsize=11, fontweight="bold")
    ax3.set_xlabel("Yıl"); ax3.set_ylabel("₺")
    ax3.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    plt.tight_layout()

    return fig1, fig2, fig3, pd.DataFrame(odeme_plani), emisyon_azalma, emisyon_azalma_pct, kum_e_ref, kum_e_yeni


def grafik_genel_karsilastirma(senaryolar, emisyonlar, amorti_yillari):
    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    fig.suptitle("Tüm Senaryolar – Maliyet ve Emisyon Özeti (Başabaş Bazlı)",
                 fontsize=13, fontweight="bold")

    ax1 = axes[0]
    ax1.axhline(0, color="black", linewidth=1.2, linestyle="--", alpha=0.6)
    ref_s = senaryolar["Mevcut Durum"]

    for ad, s in senaryolar.items():
        if ad == "Mevcut Durum":
            continue
        ay = amorti_yillari.get(ad)
        n  = ay if ay else MAX_AMORTI_YIL
        yatirim = arac_yatirim_maliyeti(s)
        ab = sum((1 + tufe_oran)**k for k in range(n))
        baz = yatirim / ab if ab else 0
        kum = 0
        netleri = []
        for yil in range(1, n + 1):
            tc = (1 + tufe_oran) ** (yil - 1)
            ts = (
                yillik_yakit_maliyeti(ref_s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
                yillik_bakim_maliyeti(ref_s, tc)
            ) - (
                yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
                yillik_bakim_maliyeti(s, tc)
            )
            kum += ts - baz * tc
            netleri.append(kum)
        lbl = f"{ad} ({'Yıl ' + str(ay) if ay else 'Başabaş Yok'})"
        ax1.plot(list(range(1, n+1)), netleri, color=RENKLER[ad],
                 linewidth=2.5, marker="o", markersize=4, label=lbl)
    ax1.set_title("Kümülatif Net Tasarruf (Mevcut Duruma Göre)", fontsize=10, fontweight="bold")
    ax1.set_xlabel("Yıl"); ax1.set_ylabel("₺")
    ax1.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    ax1.legend(fontsize=8)

    ax2 = axes[1]
    senaryo_adlari = list(senaryolar.keys())
    wtw_vals = [emisyonlar[ad]["WTW_CO2"] for ad in senaryo_adlari]
    bars = ax2.bar(senaryo_adlari, wtw_vals, color=[RENKLER[ad] for ad in senaryo_adlari],
                   alpha=0.85, edgecolor="white")
    ref_val = emisyonlar["Mevcut Durum"]["WTW_CO2"]
    for bar, val, ad in zip(bars, wtw_vals, senaryo_adlari):
        az = (ref_val - val) / ref_val * 100 if ref_val > 0 and ad != "Mevcut Durum" else 0
        lbl = f"{val:,.0f} ton" + (f"\n(−%{az:.0f})" if az > 0 else "")
        ax2.text(bar.get_x() + bar.get_width()/2, bar.get_height() + max(wtw_vals)*0.01,
                 lbl, ha="center", va="bottom", fontsize=9, fontweight="bold")
    ax2.set_title("Yıllık WTW CO₂e Emisyonu (ton/yıl)", fontsize=10, fontweight="bold")
    ax2.set_ylabel("CO₂e (ton/yıl)")
    ax2.set_xticklabels(senaryo_adlari, rotation=15, ha="right")
    plt.tight_layout()
    return fig

