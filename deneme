# ─── ARKA PLAN MOTORU ──────────────────────────────────────────────────────────
def dinamik_analiz_motoru():
    p = st.session_state
    yillar = list(range(1, p.analiz_yili + 1))
    enflasyon = p.tufe / 100.0

    def senaryo_hesapla(elektrik_orani, altyapi_yatirimi):
        e_arac = round(p.arac_sayisi * elektrik_orani)
        y_arac = p.arac_sayisi - e_arac
        arac_yatirim = e_arac * (p.elektrik_arac_birim_maliyet - p.yakit_arac_birim_maliyet)
        toplam_ilk_yatirim = max(0, arac_yatirim) + altyapi_yatirimi

        kumulatif_kar = -toplam_ilk_yatirim
        bas_bas = None
        veriler = []

        for yil in yillar:
            bf = (1 + enflasyon) ** (yil - 1)
            mevcut_gider = p.arac_sayisi * 12 * ((p.aylik_yakit_gideri + p.aylik_bakim_gideri) * bf)
            e_gider = e_arac * 12 * ((p.aylik_elektrik_gideri + p.aylik_elektrik_bakim_gideri) * bf)
            y_gider = y_arac * 12 * ((p.aylik_yakit_gideri + p.aylik_bakim_gideri) * bf)
            senaryo_gider = e_gider + y_gider

            yillik_tasarruf = mevcut_gider - senaryo_gider
            kumulatif_kar += yillik_tasarruf

            if bas_bas is None and kumulatif_kar >= 0:
                bas_bas = yil

            veriler.append({
                "yil": yil, "kumulatif_kar": kumulatif_kar, "yillik_tasarruf": yillik_tasarruf,
                "mevcut_gider": mevcut_gider, "senaryo_gider": senaryo_gider
            })
        return {"veriler": veriler, "bas_bas": bas_bas, "toplam_ilk_yatirim": toplam_ilk_yatirim, "e_arac": e_arac}

    return senaryo_hesapla(1/3, p.altyapi_s1), senaryo_hesapla(2/3, p.altyapi_s2), senaryo_hesapla(1.0, p.altyapi_s3), yillar

# ─── ADIM 4: SONUÇLAR ────────────────────────────────────────────────────────
