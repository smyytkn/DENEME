    # Eksik olan AHP Algoritmasının matematiksel simülasyonu
    # Kriter 1: Ekonomik Maliyet Skoru (Düşük maliyet yüksek puan)
    maliyetler = np.array([df_s1["toplam"].sum(), df_s2["toplam"].sum(), df_s3["toplam"].sum()])
    maliyet_skorlari = 1 / (maliyetler / maliyetler.min())
    maliyet_skorlari /= maliyet_skorlari.sum()
    
    # Kriter 2: Çevresel Emisyon Skoru (Düşük emisyon yüksek puan)
    emisyonlar = np.array([em_s1["CO2e_ton"], em_s2["CO2e_ton"], em_s3["CO2e_ton"]])
    emisyon_skorlari = 1 / (emisyonlar / emisyonlar.min())
    emisyon_skorlari /= emisyon_skorlari.sum()
    
    # AHP Ağırlıklı Hesaplama
    w_cost = 1.0 - ahp_emisyon_agirlik
    w_env = ahp_emisyon_agirlik
    ahp_skoru = (maliyet_skorlari * w_cost) + (emisyon_skorlari * w_env)
    
    en_iyi_index = np.argmax(ahp_skoru)
    senaryolar_kod = ["S1", "S2", "S3"]
