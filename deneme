def senaryo_tanimla(oran, n_oto, n_min, elk_oto_max, elk_min_max):
    """Her senaryo için araç dağılımını hesaplar."""
    elk_oto = round(elk_oto_max * oran)
    elk_min = round(elk_min_max * oran)
    diz_oto = n_oto - elk_oto
    diz_min = n_min - elk_min
    return {"elk_oto": elk_oto, "elk_min": elk_min,
            "diz_oto": diz_oto, "diz_min": diz_min}

senaryolar = {
    "Mevcut Durum":   senaryo_tanimla(0,    n_otobus, n_minibus, elk_otobus, elk_minibus),
    "1/3 Elektrikli": senaryo_tanimla(1/3,  n_otobus, n_minibus, elk_otobus, elk_minibus),
    "2/3 Elektrikli": senaryo_tanimla(2/3,  n_otobus, n_minibus, elk_otobus, elk_minibus),
    "Tam Elektrikli": senaryo_tanimla(1.0,  n_otobus, n_minibus, elk_otobus, elk_minibus),
}

