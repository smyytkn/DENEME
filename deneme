def senaryo_maliyet_analizi(senaryo_adi, oran_label):
    print(f"\n📊  [{oran_label}] {senaryo_adi} – Maliyet Analizi")
    renk  = RENKLER[senaryo_adi]
    s     = senaryolar[senaryo_adi]

    yatirim   = arac_yatirim_maliyeti(s)
    ref_s     = senaryolar["Mevcut Durum"]

    # Başabaş: yatırım toplamını kaç yılda amorti?
    # Her yıl mevcut durum - yeni durum farkı birikir
    kümülatif_tasarruf = 0
    amorti_yil = None
    yillik_netleri = []
    yil_odeme = []    # yatırım ödemesi yıllık
    yil_toplam = []   # toplam gider yıllık

    # Başabaş süresine yay yatırımı (TÜFE artışlı taksit)
    # 1. yıl ödeme = P / [sum_{k=0}^{n-1} (1+tufe)^k]  (annuity)
    n = ANALIZ_YILI
    annuity_bolen = sum((1 + tufe_oran)**k for k in range(n))
    baz_odeme_yil = yatirim / annuity_bolen if annuity_bolen > 0 else 0

    odeme_plani = []

    for yil in range(1, n + 1):
        tufe_kat   = (1 + tufe_oran) ** (yil - 1)
        yakit_yeni = yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
        bakim_yeni = yillik_bakim_maliyeti(s, tufe_kat)
        yakit_ref  = yillik_yakit_maliyeti(ref_s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
        bakim_ref  = yillik_bakim_maliyeti(ref_s, tufe_kat)

        tasarruf   = (yakit_ref + bakim_ref) - (yakit_yeni + bakim_yeni)

        yil_yatirim_odeme = baz_odeme_yil * tufe_kat
        net = tasarruf - yil_yatirim_odeme

        kümülatif_tasarruf += net
        yillik_netleri.append(kümülatif_tasarruf)
        yil_odeme.append(yil_yatirim_odeme)
        yil_toplam.append(yakit_yeni + bakim_yeni + yil_yatirim_odeme)

        odeme_plani.append({
            "Yıl": yil,
            "Aylık Taksit (₺)": f"{yil_yatirim_odeme/12:,.0f}",
            "Yıllık Taksit (₺)": f"{yil_yatirim_odeme:,.0f}",
            "Yıllık Tasarruf (₺)": f"{tasarruf:,.0f}",
            "Kümülatif Net (₺)": f"{kümülatif_tasarruf:,.0f}",
        })

        if amorti_yil is None and kümülatif_tasarruf >= 0:
            amorti_yil = yil

    # ── Grafik 1: Başabaş (Kümülatif Net) ──
    fig, axes = plt.subplots(1, 2, figsize=(16, 6))
    fig.suptitle(f"{senaryo_adi} – Maliyet ve Başabaş Analizi",
                 fontsize=14, fontweight="bold")

    yillar = list(range(1, n + 1))
    ax1 = axes[0]
    ax1.axhline(0, color="black", linewidth=1.2, linestyle="--", alpha=0.6)
    ax1.plot(yillar, yillik_netleri, color=renk, linewidth=2.5, marker="o", markersize=6)
    ax1.fill_between(yillar, yillik_netleri, 0,
                     where=[v >= 0 for v in yillik_netleri], alpha=0.2, color="green", label="Kâr")
    ax1.fill_between(yillar, yillik_netleri, 0,
                     where=[v < 0 for v in yillik_netleri], alpha=0.2, color="red", label="Zarar")

    if amorti_yil:
        ax1.axvline(amorti_yil, color="darkgreen", linestyle=":", linewidth=1.8)
        ax1.text(amorti_yil + 0.15, min(yillik_netleri)*0.8,
                 f"Başabaş\nYıl {amorti_yil}", color="darkgreen", fontsize=9, fontweight="bold")
    else:
        ax1.text(0.6, 0.1, "Analiz dönemi\niçinde amorti\nedilemiyor",
                 transform=ax1.transAxes, color="red", fontsize=10, ha="center")

    ax1.set_title("Başabaş Noktası (Kümülatif Kâr/Zarar)", fontsize=11, fontweight="bold")
    ax1.set_xlabel("Yıl")
    ax1.set_ylabel("Kümülatif Net Tasarruf (₺)")
    ax1.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    ax1.legend()

    # ── Grafik 2: Yıllık toplam gider ──
    ax2 = axes[1]
    ax2.bar(yillar, yil_toplam, color=renk, alpha=0.75, edgecolor="white")
    ax2.set_title("Yıllık Toplam Gider\n(Yakıt + Bakım + Taksit)", fontsize=11, fontweight="bold")
    ax2.set_xlabel("Yıl")
    ax2.set_ylabel("Toplam Gider (₺)")
    ax2.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))

    plt.tight_layout()
    fname = f"{senaryo_adi.replace('/', '_').replace(' ', '_')}_maliyet.png"
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    plt.show()
    print(f"  ✅ Grafik kaydedildi: {fname}")

    # ── Ödeme Planı Tablosu ──
    print(f"\n  📋  {senaryo_adi} – Ödeme Planı")
    print(f"  Toplam Yatırım : {fmt_number(yatirim)} ₺")
    if amorti_yil:
        print(f"  Amorti Yılı    : {amorti_yil}. Yıl")
    else:
        print(f"  Amorti Yılı    : {ANALIZ_YILI} yıl içinde gerçekleşmiyor")
    print()
    df = pd.DataFrame(odeme_plani)
    print(df.to_string(index=False))

    # ── Grafik 3: Yıllık taksit ──
    fig2, ax3 = plt.subplots(figsize=(12, 5))
    ax3.bar(yillar, yil_odeme, color=renk, alpha=0.8, edgecolor="white")
    for i, (yil, odeme) in enumerate(zip(yillar, yil_odeme)):
        ax3.text(yil, odeme + max(yil_odeme)*0.01,
                 f"{odeme/12:,.0f} ₺/ay", ha="center", va="bottom", fontsize=8.5)
    ax3.set_title(f"{senaryo_adi} – Yıllık Araç Taksit Ödemesi (TÜFE Artışlı)",
                  fontsize=12, fontweight="bold")
    ax3.set_xlabel("Yıl")
    ax3.set_ylabel("Yıllık Taksit (₺)")
    ax3.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    plt.tight_layout()
    fname2 = f"{senaryo_adi.replace('/', '_').replace(' ', '_')}_taksit.png"
    plt.savefig(fname2, dpi=150, bbox_inches="tight")
    plt.show()
    print(f"  ✅ Grafik kaydedildi: {fname2}")


