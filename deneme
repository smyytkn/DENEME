aylik_yakit_gideri = st.sidebar.number_input("Aylık Yakıt (Araç Başı ₺)", min_value=0, value=8000, step=500)
aylik_bakim_gideri = st.sidebar.number_input("Aylık Bakım (Araç Başı ₺)", min_value=0, value=2500, step=200)

# 3. Elektrikli Araç Ayarları
st.sidebar.header("⚡ Elektrikli Araç Giderleri")
elektrik_arac_birim_maliyet = st.sidebar.number_input("Elektrikli Araç Fiyatı (₺)", min_value=0, value=2200000, step=50000)
aylik_elektrik_gideri = st.sidebar.number_input("Aylık Şarj (Araç Başı ₺)", min_value=0, value=3200, step=200)
aylik_elektrik_bakim_gideri = st.sidebar.number_input("Aylık Bakım (Araç Başı ₺)", min_value=0, value=1200, step=100)

# 4. Altyapı Ayarları
st.sidebar.header("🏗️ Altyapı Yatırımları (₺)")
altyapi_s1 = st.sidebar.number_input("Senaryo 1 (1/3 Geçiş) Altyapı", min_value=0, value=500000, step=50000)
altyapi_s2 = st.sidebar.number_input("Senaryo 2 (2/3 Geçiş) Altyapı", min_value=0, value=900000, step=50000)
altyapi_s3 = st.sidebar.number_input("Senaryo 3 (Tam Geçiş) Altyapı", min_value=0, value=1500000, step=50000)

# ─── HESAPLAMA MOTORU ─────────────────────────────────────────────────────────
yillar = list(range(1, int(analiz_yili) + 1))
enflasyon = float(tufe) / 100.0

def senaryo_hesapla(elektrik_orani, altyapi_yatirimi):
    e_arac = round(int(arac_sayisi) * elektrik_orani)
    y_arac = int(arac_sayisi) - e_arac
    arac_yatirim = e_arac * (int(elektrik_arac_birim_maliyet) - int(yakit_arac_birim_maliyet))
    toplam_ilk_yatirim = max(0, arac_yatirim) + int(altyapi_yatirimi)

    kumulatif_kar = -toplam_ilk_yatirim
    bas_bas = None
    veriler = []

    for yil in yillar:
        bf = (1 + enflasyon) ** (yil - 1)
        mevcut_gider = int(arac_sayisi) * 12 * ((int(aylik_yakit_gideri) + int(aylik_bakim_gideri)) * bf)
        e_gider = e_arac * 12 * ((int(aylik_elektrik_gideri) + int(aylik_elektrik_bakim_gideri)) * bf)
        y_gider = y_arac * 12 * ((int(aylik_yakit_gideri) + int(aylik_bakim_gideri)) * bf)
        senaryo_gider = e_gider + y_gider

        yillik_tasarruf = mevcut_gider - senaryo_gider
        kumulatif_kar += yillik_tasarruf

        if bas_bas is None and kumulatif_kar >= 0:
            bas_bas = yil

        veriler.append({
            "yil": yil, "kumulatif_kar": kumulatif_kar, "yillik_tasarruf": yillik_tasarruf,
            "mevcut_gider": mevcut_gider, "senaryo_gider": senaryo_gider
        })
    return {"veriler": veriler, "bas_bas": bas_bas, "toplam_ilk_yatirim": toplam_ilk_yatirim, "e_arac": e_arac}

# Hesaplamaları çalıştır
s1 = senaryo_hesapla(1/3, altyapi_s1)
s2 = senaryo_hesapla(2/3, altyapi_s2)
s3 = senaryo_hesapla(1.0, altyapi_s3)

