def grafik_genel_karsilastirma():
    print("\n📊  Tüm Senaryolar – Genel Karşılaştırma")
    yillar = list(range(1, ANALIZ_YILI + 1))
    n = ANALIZ_YILI

    fig, axes = plt.subplots(1, 2, figsize=(16, 6))
    fig.suptitle("Tüm Senaryolar – 10 Yıllık Maliyet ve Emisyon Özeti",
                 fontsize=14, fontweight="bold")

    # Sol: Kümülatif net karşılaştırma
    ax1 = axes[0]
    ax1.axhline(0, color="black", linewidth=1.2, linestyle="--", alpha=0.6)

    ref_s = senaryolar["Mevcut Durum"]
    for senaryo_adi, s in senaryolar.items():
        if senaryo_adi == "Mevcut Durum":
            continue
        yatirim = arac_yatirim_maliyeti(s)
        annuity_bolen = sum((1 + tufe_oran)**k for k in range(n))
        baz_odeme = yatirim / annuity_bolen if annuity_bolen else 0

        kum = 0
        netleri = []
        for yil in range(1, n + 1):
            tufe_kat   = (1 + tufe_oran) ** (yil - 1)
            yakit_yeni = yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
            bakim_yeni = yillik_bakim_maliyeti(s, tufe_kat)
            yakit_ref  = yillik_yakit_maliyeti(ref_s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat)
            bakim_ref  = yillik_bakim_maliyeti(ref_s, tufe_kat)
            tasarruf   = (yakit_ref + bakim_ref) - (yakit_yeni + bakim_yeni)
            kum += tasarruf - baz_odeme * tufe_kat
            netleri.append(kum)

        ax1.plot(yillar, netleri, color=RENKLER[senaryo_adi],
                 linewidth=2.5, marker="o", markersize=5, label=senaryo_adi)

    ax1.set_title("Kümülatif Net Tasarruf / Maliyet\n(Mevcut Duruma Göre)", fontsize=11, fontweight="bold")
    ax1.set_xlabel("Yıl")
    ax1.set_ylabel("Kümülatif Net (₺)")
    ax1.yaxis.set_major_formatter(mticker.FuncFormatter(format_tl))
    ax1.legend()

    # Sağ: Yıllık WTW emisyon karşılaştırması (bar)
    ax2 = axes[1]
    senaryo_adlari = list(senaryolar.keys())
    wtw_vals = [emisyonlar[ad]["WTW_CO2"] for ad in senaryo_adlari]
    renkler  = [RENKLER[ad] for ad in senaryo_adlari]
    bars = ax2.bar(senaryo_adlari, wtw_vals, color=renkler, alpha=0.85,
                   edgecolor="white", linewidth=0.8)

    for bar, val in zip(bars, wtw_vals):
        ax2.text(bar.get_x() + bar.get_width()/2, bar.get_height() + max(wtw_vals)*0.01,
                 f"{val:,.0f}\nton", ha="center", va="bottom", fontsize=9, fontweight="bold")

    ax2.set_title("Yıllık WTW CO₂e Emisyonu\n(ton/yıl)", fontsize=11, fontweight="bold")
    ax2.set_ylabel("CO₂e (ton/yıl)")
    ax2.set_xticklabels(senaryo_adlari, rotation=15, ha="right")

    plt.tight_layout()
    plt.savefig("genel_karsilastirma.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("  ✅ Grafik kaydedildi: genel_karsilastirma.png\n")

