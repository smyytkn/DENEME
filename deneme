        fig.add_shape(type="line", x0=1, y0=0, x1=max(yillar), y1=0, line=dict(color=COLORS['current'], width=2, dash="dash"))
        fig.update_layout(title="Kümülatif Kâr / Zarar Projeksiyonu (Başıbaş Çizgisi = 0)", **chart_layout)
        st.plotly_chart(fig, use_container_width=True)

    elif "Tasarruf" in chart_type:
        fig = fgo.Figure()
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['yillik_tasarruf'] for v in s1['veriler']], name="S1 Yıllık Tasarruf", stackgroup="one", line=dict(color=COLORS['s1'])))
