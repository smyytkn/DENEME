def yillik_yakit_maliyeti(s, km_oto, km_min, dizel_f, elek_f):
    """Yıllık toplam yakıt / enerji maliyeti (₺)"""
    m_diz_oto = s["diz_oto"] / max(n_otobus, 1) * km_oto * OTOBÜS_DIZEL_TUKETIM * dizel_f if n_otobus > 0 else 0
    m_elk_oto = s["elk_oto"] / max(n_otobus, 1) * km_oto * OTOBÜS_ELK_TUKETIM  * elek_f  if n_otobus > 0 else 0
    m_diz_min = s["diz_min"] / max(n_minibus,1) * km_min * MINIBÜS_DIZEL_TUKETIM * dizel_f if n_minibus > 0 else 0
    m_elk_min = s["elk_min"] / max(n_minibus,1) * km_min * MINIBÜS_ELK_TUKETIM  * elek_f  if n_minibus > 0 else 0

    # Tüm araçların paylaşımlı km'si üzerinden (filo bazlı)
    m_diz_oto2 = s["diz_oto"] * (km_oto / max(n_otobus,1)) * OTOBÜS_DIZEL_TUKETIM * dizel_f
    m_elk_oto2 = s["elk_oto"] * (km_oto / max(n_otobus,1)) * OTOBÜS_ELK_TUKETIM  * elek_f
    m_diz_min2 = s["diz_min"] * (km_min / max(n_minibus,1)) * MINIBÜS_DIZEL_TUKETIM * dizel_f
    m_elk_min2 = s["elk_min"] * (km_min / max(n_minibus,1)) * MINIBÜS_ELK_TUKETIM  * elek_f
    return m_diz_oto2 + m_elk_oto2 + m_diz_min2 + m_elk_min2

def yillik_bakim_maliyeti(s, tufe_katsayi=1.0):
    """Yıllık toplam bakım maliyeti (₺) – TÜFE katsayısı uygulanmış"""
    return (s["diz_oto"]  * bakim_diz_otobus  +
            s["diz_min"]  * bakim_diz_minibus  +
            s["elk_oto"]  * bakim_elk_otobus   +
            s["elk_min"]  * bakim_elk_minibus) * tufe_katsayi

def arac_yatirim_maliyeti(s):
    """Elektrikliye geçen araçların toplam yatırım maliyeti (₺)"""
    return (s["elk_oto"] * fiyat_elk_otobus +
            s["elk_min"] * fiyat_elk_minibus)

