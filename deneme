}

# ─── YARDIMCI FONKSİYONLAR ────────────────────────────────────────────────────
def fmt_k(n):
    if abs(n) >= 1_000_000:
        return f"{n / 1_000_000:.1f}M ₺"
    if abs(n) >= 1_000:
        return f"{n / 1_000:.0f}K ₺"
    return f"{n:,.0f} ₺".replace(",", ".")

# ─── GÜVENLİ YERLEŞİK ÜST BAŞLIK ──────────────────────────────────────────────
st.caption("⚡ ELEKTRİKLİ ARAÇ GEÇİŞ ANALİZİ")
