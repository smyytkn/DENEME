        fig.add_trace(fgo.Scatter(x=yillar, y=[v['kumulatif_kar'] for v in s2['veriler']], name="Senaryo 2 (2/3)", line=dict(color=COLORS['s2'], width=3)))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['kumulatif_kar'] for v in s3['veriler']], name="Senaryo 3 (Tam)", line=dict(color=COLORS['s3'], width=3)))
        fig.add_shape(type="line", x0=1, y0=0, x1=max(yillar), y1=0, line=dict(color=COLORS['current'], width=2, dash="dash"))
        fig.update_layout(title="Kümülatif Kâr / Zarar Projeksiyonu", **chart_layout)
        st.plotly_chart(fig, use_container_width=True, key="plotly_breakeven")

    elif "Tasarruf" in chart_type:
        fig = fgo.Figure()
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['yillik_tasarruf'] for v in s1['veriler']], name="S1 Tasarruf", fill='tonexty', line=dict(color=COLORS['s1'])))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['yillik_tasarruf'] for v in s2['veriler']], name="S2 Tasarruf", fill='tonexty', line=dict(color=COLORS['s2'])))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['yillik_tasarruf'] for v in s3['veriler']], name="S3 Tasarruf", fill='tonexty', line=dict(color=COLORS['s3'])))
        fig.update_layout(title="Net Yıllık İşletme Tasarrufu", **chart_layout)
        st.plotly_chart(fig, use_container_width=True, key="plotly_savings")

    elif "Gideri" in chart_type:
        fig = fgo.Figure()
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['mevcut_gider'] for v in s1['veriler']], name="Mevcut Gider", line=dict(color=COLORS['current'], width=3, dash="dot")))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['senaryo_gider'] for v in s1['veriler']], name="Senaryo 1 Gider", line=dict(color=COLORS['s1'])))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['senaryo_gider'] for v in s2['veriler']], name="Senaryo 2 Gider", line=dict(color=COLORS['s2'])))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['senaryo_gider'] for v in s3['veriler']], name="Senaryo 3 Gider", line=dict(color=COLORS['s3'])))
        fig.update_layout(title="Yıllık Toplam İşletme Maliyetleri Karşılaştırması", **chart_layout)
        st.plotly_chart(fig, use_container_width=True, key="plotly_opex")

    st.markdown("### 📋 Yıllık Detay Tablosu")
    detay_rows = []
    for idx, yil in enumerate(yillar):
        detay_rows.append({
            "Yıl": f"{yil}. Yıl",
            "Mevcut Gider": fmt_k(s1['veriler'][idx]['mevcut_gider']),
            "S1 Kümülatif Kâr": fmt_k(s1['veriler'][idx]['kumulatif_kar']),
            "S2 Kümülatif Kâr": fmt_k(s2['veriler'][idx]['kumulatif_kar']),
            "S3 Kümülatif Kâr": fmt_k(s3['veriler'][idx]['kumulatif_kar']),
        })
    st.dataframe(pd.DataFrame(detay_rows).set_index("Yıl"), use_container_width=True, key="df_detay_tablo")

