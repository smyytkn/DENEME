        em = [em_md, em_s1, em_s2, em_s3][idx]
        df_ = [df_md, df_s1, df_s2, df_s3][idx]
        bb = [None, bb_s1, bb_s2, bb_s3][idx]
        ahp = "-" if kod == "MD" else f"{ahp_skoru[idx-1]:.4f}"
        
        veriler.append({
            "Senaryo": ETIKET[kod],
            "Yıllık CO₂e (Ton)": f"{em['CO2e_ton']:,.1f}",
            "15 Yıllık Toplam Gider": f"{df_['toplam'].sum()/1e9:.3f} Milyar TL",
            "Yatırım Geri Dönüşü": "-" if kod == "MD" else ay_yil_str(bb),
            "AHP Sentez Skoru": ahp
        })
        
    st.table(pd.DataFrame(veriler))
    
