@st.cache_data(ttl=3600)
def fetch_diesel_price():
    headers = {"User-Agent": "Mozilla/5.0"}
    try:
        r = requests.get("https://www.epdk.gov.tr/Detay/Icerik/3-0-24-4/akaryakitfiyatlari",
                         headers=headers, timeout=8)
        m = re.search(r"motorin[^0-9]*([0-9]+[,\.][0-9]+)", r.text, re.IGNORECASE)
        if m:
            return float(m.group(1).replace(",", "."))
    except:
        pass
    return None

@st.cache_data(ttl=3600)
def fetch_electricity_price():
    headers = {"User-Agent": "Mozilla/5.0"}
    try:
        r = requests.get("https://www.epdk.gov.tr/Detay/Icerik/3-0-24-6/elektrik",
                         headers=headers, timeout=8)
        m = re.search(r"([0-9]+[,\.][0-9]+)\s*(TL|₺).*?kWh", r.text, re.IGNORECASE)
        if m:
            return float(m.group(1).replace(",", "."))
    except:
        pass
    return None

@st.cache_data(ttl=3600)
def fetch_tufe():
    try:
        r = requests.get("https://data.tuik.gov.tr/api/Gosterge?id=5001&dil=1", timeout=8)
        d = r.json()
        val = d.get("value") or d.get("Value")
        if val:
            return float(val) / 100
    except:
        pass
    return None

def fmt_number(n):
    try:
        return f"{float(n):,.0f}".replace(",", ".")
    except:
        return str(n)

def format_tl(x, pos=None):
    return f"{x/1e6:.1f}M ₺" if abs(x) >= 1e6 else f"{x/1e3:.0f}K ₺"

