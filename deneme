st.sidebar.header("🚗 Genel Filo Ayarları")
arac_sayisi = st.sidebar.number_input("Toplam Araç Sayısı", min_value=1, value=30, step=1)
analiz_yili = st.sidebar.number_input("Analiz Süresi (Yıl)", min_value=3, max_value=20, value=8, step=1)
tufe = st.sidebar.number_input("Yıllık TÜFE Oranı (%)", min_value=0.0, value=35.0, step=0.5)

# 2. Yakıtlı Araç Ayarları
st.sidebar.header("⛽ Yakıtlı Araç Giderleri")
