        fig.add_trace(fgo.Scatter(x=yillar, y=[v['senaryo_gider'] for v in s2['veriler']], name="Senaryo 2 Gider", line=dict(color=COLORS['s2'])))
        fig.add_trace(fgo.Scatter(x=yillar, y=[v['senaryo_gider'] for v in s3['veriler']], name="Senaryo 3 Gider", line=dict(color=COLORS['s3'])))
        fig.update_layout(title="Yıllık Toplam İşletme Maliyetleri Karşılaştırması", **chart_layout)
        st.plotly_chart(fig, use_container_width=True)

    # Detaylı Tablo Alanı
    st.markdown("### 📋 Yıllık Detay Tablosu")
    detay_rows = []
    for idx, yil in enumerate(yillar):
        detay_rows.append({
            "Yıl": f"{yil}. Yıl",
            "Mevcut Yıllık Gider": fmt_k(s1['veriler'][idx]['mevcut_gider']),
            "S1 Kümülatif Kâr": fmt_k(s1['veriler'][idx]['kumulatif_kar']),
            "S2 Kümülatif Kâr": fmt_k(s2['veriler'][idx]['kumulatif_kar']),
            "S3 Kümülatif Kâr": fmt_k(s3['veriler'][idx]['kumulatif_kar']),
        })
    st.dataframe(pd.DataFrame(detay_rows).set_index("Yıl"), use_container_width=True)

