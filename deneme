#  EMİSYON HESAPLAMA  (Tez Formülü)
# ════════════════════════════════════════════════════════════
"""
Tez Emisyon Formülü:
  E_total = E_yakım + E_upstream
  E_yakım_dizel  = km * tüketim(L/km) * EF_dizel_yakım
  E_yakım_elk    = km * tüketim(kWh/km) * EF_elektrik_tüketim
  E_upstream_diz = km * tüketim(L/km) * EF_dizel_upstream
  E_upstream_elk = km * tüketim(kWh/km) * EF_elektrik_upstream
  WTW (Well-to-Wheel) = E_yakım + E_upstream
"""

def emisyon_hesapla(s, km_oto, km_min):
    """
    s : senaryo sözlüğü
    Döner: dict – CO₂e ton/yıl (TTW, WTT, WTW) hem otobüs hem minibüs hem toplam
    """
    # Otobüs – Dizel
    e_ttw_diz_oto = (s["diz_oto"] > 0) * km_oto * OTOBÜS_DIZEL_TUKETIM * EF_DIZEL_YAKIM
    e_wtt_diz_oto = (s["diz_oto"] > 0) * km_oto * OTOBÜS_DIZEL_TUKETIM * EF_DIZEL_UPSTREAM

    # Otobüs – Elektrikli
    e_ttw_elk_oto = (s["elk_oto"] > 0) * km_oto * OTOBÜS_ELK_TUKETIM * EF_ELEKTRIK_TUKETIM
    e_wtt_elk_oto = (s["elk_oto"] > 0) * km_oto * OTOBÜS_ELK_TUKETIM * EF_ELEKTRIK_UPSTREAM

    # Minibüs – Dizel
    e_ttw_diz_min = (s["diz_min"] > 0) * km_min * MINIBÜS_DIZEL_TUKETIM * EF_DIZEL_YAKIM
    e_wtt_diz_min = (s["diz_min"] > 0) * km_min * MINIBÜS_DIZEL_TUKETIM * EF_DIZEL_UPSTREAM

    # Minibüs – Elektrikli
    e_ttw_elk_min = (s["elk_min"] > 0) * km_min * MINIBÜS_ELK_TUKETIM * EF_ELEKTRIK_TUKETIM
    e_wtt_elk_min = (s["elk_min"] > 0) * km_min * MINIBÜS_ELK_TUKETIM * EF_ELEKTRIK_UPSTREAM

    ttw_total = (e_ttw_diz_oto + e_ttw_elk_oto + e_ttw_diz_min + e_ttw_elk_min)
    wtt_total = (e_wtt_diz_oto + e_wtt_elk_oto + e_wtt_diz_min + e_wtt_elk_min)

    return {
        "TTW_CO2": ttw_total / 1000,  # → ton CO₂e/yıl
        "WTT_CO2": wtt_total / 1000,
        "WTW_CO2": (ttw_total + wtt_total) / 1000,
        "NOx":     ttw_total * 0.0015 / 1000,   # yaklaşık NOx faktörü
        "PM":      ttw_total * 0.00008 / 1000,  # PM faktörü
        "HC":      ttw_total * 0.0003 / 1000,
    }

emisyonlar = {ad: emisyon_hesapla(s, km_otobus, km_minibus) for ad, s in senaryolar.items()}

