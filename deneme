    while True:
        try:
            v = int(input("  " + mesaj + ": "))
            if v >= min_val:
                return v
            print(f"  ✗ Lütfen {min_val} veya daha büyük bir tam sayı girin.")
        except ValueError:
            print("  ✗ Geçersiz giriş, lütfen tam sayı girin.")

def giris_float(mesaj, min_val=0.0):
