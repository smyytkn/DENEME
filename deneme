def fmt_number(n):
    """Sayıyı Türkçe noktalı biçime çevirir."""
    try:
        return f"{float(n):,.0f}".replace(",", ".")
    except:
        return str(n)

def fetch_diesel_price():
    """
    EPDK günlük akaryakıt fiyatını çeker.
    Kaynak: https://www.epdk.gov.tr  (Resmi Kurum)
    Erişilemezse kullanıcıdan manuel giriş istenir.
    """
    urls = [
        "https://www.epdk.gov.tr/Detay/Icerik/3-0-24-4/akaryakitfiyatlari",
    ]
    headers = {"User-Agent": "Mozilla/5.0"}
    for url in urls:
        try:
            r = requests.get(url, headers=headers, timeout=8)
            m = re.search(r"motorin[^0-9]*([0-9]+[,\.][0-9]+)", r.text, re.IGNORECASE)
            if m:
                return float(m.group(1).replace(",", "."))
        except:
            pass
    return None

def fetch_electricity_price():
    """
    EPDK / TEDAŞ mesken elektrik tarifesini çeker.
    """
    urls = [
        "https://www.epdk.gov.tr/Detay/Icerik/3-0-24-6/elektrik",
    ]
    headers = {"User-Agent": "Mozilla/5.0"}
    for url in urls:
        try:
            r = requests.get(url, headers=headers, timeout=8)
            m = re.search(r"([0-9]+[,\.][0-9]+)\s*(TL|₺).*?kWh", r.text, re.IGNORECASE)
            if m:
                return float(m.group(1).replace(",", "."))
        except:
            pass
    return None

def fetch_tufe():
    """
    TÜİK TÜFE yıllık oranını çeker.
    Kaynak: https://www.tuik.gov.tr
    """
    try:
        r = requests.get(
            "https://data.tuik.gov.tr/api/Gosterge?id=5001&dil=1",
            timeout=8
        )
        d = r.json()
        val = d.get("value") or d.get("Value")
        if val:
            return float(val) / 100
    except:
        pass
    # Alternatif
    try:
        r = requests.get("https://www.tuik.gov.tr/api/enflasyon", timeout=8)
        d = r.json()
        return float(d["yillik"]) / 100
    except:
        pass
    return None

def input_float(prompt, default=None):
    """Ondalık sayı girişi; Türkçe virgül kabul eder."""
    while True:
        try:
            val = input(prompt).strip().replace(".", "").replace(",", ".")
            return float(val)
        except:
            if default is not None:
                return default
            print("  ⚠ Geçersiz değer, lütfen tekrar girin.")

def input_int(prompt, default=None):
    while True:
        try:
            val = input(prompt).strip().replace(".", "").replace(",", "")
            return int(val)
        except:
            if default is not None:
                return default
            print("  ⚠ Geçersiz değer, lütfen tekrar girin.")

def format_tl(x, pos=None):
    return f"{x/1e6:.1f}M ₺" if abs(x) >= 1e6 else f"{x/1e3:.0f}K ₺"

