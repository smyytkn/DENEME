def senaryo_tanimla(oran, n_oto, n_min, elk_oto_max, elk_min_max):
    elk_oto = round(elk_oto_max * oran)
    elk_min = round(elk_min_max * oran)
    return {"elk_oto": elk_oto, "elk_min": elk_min,
            "diz_oto": n_oto - elk_oto, "diz_min": n_min - elk_min}

def emisyon_hesapla(s, km_oto, km_min):
    e_ttw = (
        (s["diz_oto"] > 0) * km_oto * OTOBÜS_DIZEL_TUKETIM * EF_DIZEL_YAKIM +
        (s["elk_oto"] > 0) * km_oto * OTOBÜS_ELK_TUKETIM   * EF_ELEKTRIK_TUKETIM +
        (s["diz_min"] > 0) * km_min * MINIBÜS_DIZEL_TUKETIM * EF_DIZEL_YAKIM +
        (s["elk_min"] > 0) * km_min * MINIBÜS_ELK_TUKETIM   * EF_ELEKTRIK_TUKETIM
    )
    e_wtt = (
        (s["diz_oto"] > 0) * km_oto * OTOBÜS_DIZEL_TUKETIM * EF_DIZEL_UPSTREAM +
        (s["elk_oto"] > 0) * km_oto * OTOBÜS_ELK_TUKETIM   * EF_ELEKTRIK_UPSTREAM +
        (s["diz_min"] > 0) * km_min * MINIBÜS_DIZEL_TUKETIM * EF_DIZEL_UPSTREAM +
        (s["elk_min"] > 0) * km_min * MINIBÜS_ELK_TUKETIM   * EF_ELEKTRIK_UPSTREAM
    )
    return {
        "TTW_CO2": e_ttw / 1000,
        "WTT_CO2": e_wtt / 1000,
        "WTW_CO2": (e_ttw + e_wtt) / 1000,
        "NOx":     e_ttw * 0.0015 / 1000,
        "PM":      e_ttw * 0.00008 / 1000,
        "HC":      e_ttw * 0.0003 / 1000,
    }

def yillik_yakit_maliyeti(s, km_oto, km_min, dizel_f, elek_f):
    return (
        s["diz_oto"] * (km_oto / max(n_otobus, 1)) * OTOBÜS_DIZEL_TUKETIM * dizel_f +
        s["elk_oto"] * (km_oto / max(n_otobus, 1)) * OTOBÜS_ELK_TUKETIM   * elek_f +
        s["diz_min"] * (km_min / max(n_minibus, 1)) * MINIBÜS_DIZEL_TUKETIM * dizel_f +
        s["elk_min"] * (km_min / max(n_minibus, 1)) * MINIBÜS_ELK_TUKETIM   * elek_f
    )

def yillik_bakim_maliyeti(s, tufe_kat=1.0):
    return (
        s["diz_oto"] * bakim_diz_otobus +
        s["diz_min"] * bakim_diz_minibus +
        s["elk_oto"] * bakim_elk_otobus +
        s["elk_min"] * bakim_elk_minibus
    ) * tufe_kat

def arac_yatirim_maliyeti(s):
    return s["elk_oto"] * fiyat_elk_otobus + s["elk_min"] * fiyat_elk_minibus

def amorti_yili_bul(s, ref_s):
    yatirim = arac_yatirim_maliyeti(s)
    if yatirim == 0:
        return 0
    annuity_b = sum((1 + tufe_oran)**k for k in range(MAX_AMORTI_YIL))
    baz_odeme = yatirim / annuity_b if annuity_b > 0 else 0
    kum = 0
    for yil in range(1, MAX_AMORTI_YIL + 1):
        tufe_kat   = (1 + tufe_oran) ** (yil - 1)
        tasarruf   = (
            yillik_yakit_maliyeti(ref_s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
            yillik_bakim_maliyeti(ref_s, tufe_kat)
        ) - (
            yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
            yillik_bakim_maliyeti(s, tufe_kat)
        )
        kum += tasarruf - baz_odeme * tufe_kat
        if kum >= 0:
            return yil
    return None

