    for col, ad in zip(cols, ["1/3 Elektrikli", "2/3 Elektrikli", "Tam Elektrikli"]):
        ay = amorti_yillari[ad]
        with col:
            if ay:
                st.metric(ad, f"Yıl {ay}", delta=f"Analiz: {ay} yıl")
            else:
                st.metric(ad, f"{MAX_AMORTI_YIL} yıl içinde yok", delta="Başabaş bulunamadı", delta_color="inverse")

    st.divider()

    # ── Emisyon Grafiği ──
    st.subheader("🌍 Senaryo Bazlı Emisyon Karşılaştırması")
    fig_e = grafik_emisyon(emisyonlar, senaryolar)
    st.pyplot(fig_e)
    plt.close(fig_e)

    st.divider()

    # ── Mevcut Durum ──
    st.subheader("📊 Mevcut Durum – Aylık Gider Trendi")
    fig_md = grafik_mevcut_durum(min_amorti, senaryolar)
    st.pyplot(fig_md)
    plt.close(fig_md)

    st.divider()

    # ── Senaryo Analizleri ──
    ref_s = senaryolar["Mevcut Durum"]
    for senaryo_adi, label in [("1/3 Elektrikli", "Senaryo 2"),
                                ("2/3 Elektrikli", "Senaryo 3"),
                                ("Tam Elektrikli", "Senaryo 4")]:
        ay = amorti_yillari[senaryo_adi]
        analiz_yili = ay if ay else MAX_AMORTI_YIL
        s = senaryolar[senaryo_adi]

        with st.expander(f"📂 [{label}] {senaryo_adi} – Detaylı Analiz ({analiz_yili} yıl)", expanded=True):
            if ay:
                st.info(f"ℹ Başabaş noktası **Yıl {ay}** olarak hesaplandı. Analiz bu süreye göre yapılandırıldı.")
            else:
                st.warning(f"⚠ {MAX_AMORTI_YIL} yıl içinde başabaş sağlanamıyor. Analiz {MAX_AMORTI_YIL} yıl üzerinden gösterildi.")

            fig1, fig2, fig3, df_odeme, e_azalma, e_azalma_pct, kum_e_ref, kum_e_yeni = \
                grafik_senaryo_maliyet(senaryo_adi, s, ref_s, emisyonlar, analiz_yili, ay)

            # KPI metrikleri
            col1, col2, col3, col4 = st.columns(4)
            col1.metric("Toplam Yatırım", f"{fmt_number(arac_yatirim_maliyeti(s))} ₺")
            col2.metric("Başabaş Yılı", f"Yıl {ay}" if ay else "Bulunamadı")
            col3.metric(f"Kümülatif CO₂e Azalması ({analiz_yili} yıl)", f"{e_azalma:,.1f} ton")
            col4.metric("Emisyon Azalma Oranı", f"%{e_azalma_pct:.1f}")

            st.pyplot(fig1); plt.close(fig1)
            st.pyplot(fig2); plt.close(fig2)
            st.pyplot(fig3); plt.close(fig3)

            st.markdown("**📋 Ödeme Planı (Başabaş Süresince)**")
            st.dataframe(df_odeme, use_container_width=True)

        st.divider()

    # ── Genel Karşılaştırma ──
    st.subheader("📊 Tüm Senaryolar – Genel Karşılaştırma")
    fig_gk = grafik_genel_karsilastirma(senaryolar, emisyonlar, amorti_yillari)
    st.pyplot(fig_gk)
    plt.close(fig_gk)

    st.divider()

    # ── En İyi Senaryo ──
    st.subheader("🏆 En İyi Senaryo Analizi")
    sonuc = []
    for ad, s in senaryolar.items():
        ay = amorti_yillari.get(ad, MAX_AMORTI_YIL) if ad != "Mevcut Durum" else 0
        n  = ay if ay else MAX_AMORTI_YIL
        toplam_m = sum(
            yillik_yakit_maliyeti(s, km_otobus, km_minibus, dizel_fiyat, elektrik_fiyat) +
            yillik_bakim_maliyeti(s, (1 + tufe_oran) ** (yil - 1))
            for yil in range(1, n + 1)
        )
        ort_m = toplam_m / n if n > 0 else toplam_m
        skor  = 0.6 * ort_m + 0.4 * emisyonlar[ad]["WTW_CO2"] * 1e6
        sonuc.append({
            "Senaryo":                  ad,
            "Başabaş Yılı":             str(ay) if ad != "Mevcut Durum" else "—",
            "Yatırım (₺)":              fmt_number(arac_yatirim_maliyeti(s)),
            "Ort. Yıllık Maliyet (₺)": fmt_number(ort_m),
            "WTW Emisyon (ton/yıl)":    f"{emisyonlar[ad]['WTW_CO2']:,.1f}",
            "Skor (↓ iyi)":             f"{skor:,.0f}",
        })
    df_sonuc = pd.DataFrame(sonuc)
    en_iyi   = min(sonuc, key=lambda x: float(x["Skor (↓ iyi)"].replace(".", "").replace(",", ".")))

    st.dataframe(df_sonuc, use_container_width=True)
    st.success(f"✅ En İyi Senaryo: **{en_iyi['Senaryo']}**  |  "
               f"Başabaş: {en_iyi['Başabaş Yılı']}. Yıl  |  "
               f"Ort. Maliyet: {en_iyi['Ort. Yıllık Maliyet (₺)']} ₺  |  "
               f"Emisyon: {en_iyi['WTW Emisyon (ton/yıl)']} ton CO₂e/yıl")

    # ── Özet Bilgi ──
    st.divider()
    st.subheader("📋 Analiz Özeti")
    col_a, col_b, col_c = st.columns(3)
    with col_a:
        st.write(f"**Dizel:** {fmt_number(dizel_fiyat)} ₺/litre")
        st.write(f"**Elektrik:** {fmt_number(elektrik_fiyat)} ₺/kWh")
