def basbas_hesapla(df_sen, df_md_ref, yatirim_toplam):
    tasarruf_aylik = (df_md_ref["yakıt"] + df_md_ref["bakım"]).values - (df_sen["yakıt"] + df_sen["bakım"]).values
    kumul = np.cumsum(tasarruf_aylik) - yatirim_toplam
    bb_ay = None
    for i, v in enumerate(kumul):
        if v >= 0:
            bb_ay = i + 1
            break
    return kumul, bb_ay

yatirim_s1 = n_otobüs_s1 * fiyat_otobüs_ev + n_minibüs_s1 * fiyat_minibüs_ev
yatirim_s2 = n_otobüs_s2 * fiyat_otobüs_ev + n_minibüs_s2 * fiyat_minibüs_ev
yatirim_s3 = n_otobüs_mevcut * fiyat_otobüs_ev + n_minibüs_mevcut * fiyat_minibüs_ev

